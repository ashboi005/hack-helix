# Runtime mode and local listen port
NODE_ENV=development
PORT=3000

# Public backend URL used by Better Auth for generated auth URLs
BETTER_AUTH_URL=http://localhost:3000

# Allowed frontend origin for CORS and Better Auth trusted origins
CORS_ORIGIN=http://localhost:3001

# Better Auth signing secret
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/focuslayer

# AutoSage API base URL
AUTOSAGE_BASE_URL=https://autosage.example.com

# AutoSage tenant identifier
AUTOSAGE_TENANT_ID=replace-with-your-autosage-tenant-id

# AutoSage API key
AUTOSAGE_API_KEY=replace-with-your-autosage-api-key

# Groq API key used by the Vercel AI SDK
GROQ_API_KEY=replace-with-your-groq-api-key

# Base URL for gaze tracking service
GAZE_BASE_URL=http://localhost:3001

# API key sent in request body to gaze service
GAZE_API_KEY=