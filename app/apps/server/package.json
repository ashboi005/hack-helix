{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/groq": "^2.0.16",
    "@app/auth": "workspace:*",
    "@app/db": "workspace:*",
    "@app/env": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.0.0",
    "@elysiajs/swagger": "^1.0.0",
    "@sinclair/typebox": "^0.34.15",
    "ai": "^5.0.100",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.21",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
